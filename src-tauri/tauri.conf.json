{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Claude Monitor",
  "version": "0.1.0",
  "identifier": "com.wushengzhou.claude-monitor-desktop",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Claude Monitor",
        "width": 360,
        "height": 420,
        "minWidth": 220,
        "minHeight": 120,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": true,
        "shadow": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "../server/monitor_server.py": "monitor_server.py"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
